# Notion
# Get token from https://www.notion.so/my-integrations
# (You can reuse the same integration as money_tracking — just share the parent page with it)
NOTION_TOKEN=secret_xxx

# Parent page where the "Job Applications" DB will be created.
# Open the page in Notion, ⋯ menu → Copy link, paste the URL or just the 32-char ID.
NOTION_PARENT_PAGE_ID=

# Filled in by setup_notion.py — leave blank for first run.
NOTION_DATABASE_ID=

# Gmail
# OAuth client JSON downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json
# Cached refresh token, written on first auth.
GMAIL_TOKEN_PATH=./gmail_token.json

# Bot timing
POLL_INTERVAL_SECONDS=600
# How far back to look on first run (days).
INITIAL_LOOKBACK_DAYS=180

# Optional: local LLM (Ollama) fallback for emails the heuristic classifier
# couldn't fully parse. Heuristics still run first; LLM only fills gaps.
# Setup:
#   brew install ollama
#   ollama pull llama3.2:3b   (~2GB, one-time)
#   set USE_LLM_EXTRACTION=1 below
USE_LLM_EXTRACTION=0
OLLAMA_MODEL=llama3.2:3b
